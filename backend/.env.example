# Backend deployment example
ENVIRONMENT=production
SECRET_KEY=replace-with-a-long-random-secret
DATABASE_URL=postgresql://user:password@host:5432/database
ARCHIVE_DATABASE_URL=postgresql://user:password@host:5432/archive_database

# Frontend / CORS
FRONTEND_URL=https://your-frontend.onrender.com
CORS_ORIGINS=https://your-frontend.onrender.com

# Cookie / auth
COOKIE_SECURE=true
COOKIE_SAMESITE=none
ALLOWED_COMPANY_EMAIL_DOMAINS=@ritzmediaworld.com,@ctm.co.in,@rmwcreative.in,@contenaissance.com

# Optional one-time admin bootstrap
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_ROLES=admin,root
DEFAULT_ADMIN_BOOTSTRAP_PASSWORD=

# Optional R2 storage
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
R2_REGION=auto
R2_PUBLIC_BASE_URL=

